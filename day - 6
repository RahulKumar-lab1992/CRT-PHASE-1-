  #include <iostream>
#include <string>
using namespace std;

void setTemprature(){
    cout << "Temperature Set to 22°C" << "\n";
}

void setTemprature(double temp){
    cout << "Temperature Set to " << temp << "°C" << "\n";
}

void setTemprature(string mode){
    if(mode == "ECO"){
        cout << "Temperature set to 24°C" << "\n";
    }
    else if(mode == "TURBO"){
        cout << "Temperature set to 18°C" << "\n";
    }
}

int main(){

    setTemprature();
    setTemprature(22.5);
    setTemprature("TURBO");

    return 0;
}

