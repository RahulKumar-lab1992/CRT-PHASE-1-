  //program 2 
//store discount application
  //find 10% -- amount * 0.10

#include <iostream>
using namespace std;

float discount(float amount){
    float finalAmount = amount * 0.1;
    return amount  - finalAmount;
}
int main(){
    cout << "the final price is :";
    cout << discount(100);
}


