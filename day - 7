// program 6
// Constructor Overloading

class Rectangle {

public:
    int length;
    int width;

    // Constructor 1 (Default Constructor)
    Rectangle() {
        length = 10;
        width = 20;
    }

    // Constructor 2 (Parameterized Constructor)
    Rectangle(int l) {
        length = l;
        width = 20;
    }

    // Constructor 3 (Parameterized Constructor)
    Rectangle(int l, int b) {
        length = l;
        width = b;
    }

    void area() {
        cout << length * width << "\n";
    }
};

int main() {

    Rectangle r1;
    r1.area();

    Rectangle r2(5);
    r2.area();

    Rectangle r3(5, 2);
    r3.area();

    return 0;
}
  
